
# Local development flags
# Keep AI disabled unless a secure backend proxy is configured.
VITE_ENABLE_AI=false
VITE_API_BASE_URL=

# Optional auto-translation provider for content created in Admin panel.
# In local mode, set these values in browser localStorage:
# - luna_translate_api_url
# - luna_translate_api_key

# Backend auth/admin API settings (used by `npm run api`):
# AUTH_API_PORT=8787
# SUPER_ADMIN_EMAILS=dnainform@gmail.com
# SUPER_ADMIN_BOOTSTRAP_PASSWORD=change-me
# AUTH_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# For Vercel production add your deployed domain, e.g.:
# AUTH_ALLOWED_ORIGINS=https://your-project.vercel.app
